{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "quant": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "deepseek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "sk-2c25a0afe4a64f40b6b260a9fe9eebf0"
      },
      "models": {
        "agent": {
          "id": "deepseek-reasoner",
          "name": "DeepSeek Reasoner",
          "options": {
            "maxTokens": 4096
          }
        }
      }
    }
  },
  "mcp": {
    "stocks-query": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-duckdb", "--db", "/opt/duckdb/performance_data.db"],
      "enabled": true,
      "timeout": 120000
    },
    "kline-query": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-duckdb", "--db", "/opt/duckdb/daily_k.db"],
      "enabled": true,
      "timeout": 120000
    }
  }
}
